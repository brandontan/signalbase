# ── Data Sources ──────────────────────────────────────────────
EXA_API_KEY=                    # exa.ai — semantic/neural search only
FIRECRAWL_API_KEY=              # firecrawl.dev — URL extraction fallback only
BRAVE_API_KEY=                  # search.brave.com — keyword/news search (free tier 2k/month)

# ── X API (real-time social intent — Bearer Token auth) ───────
X_BEARER_TOKEN=

# ── x402 Payments (agents pay USDC on Base) ───────────────────
PAY_TO_ADDRESS=                 # your Base wallet address
X402_NETWORK=eip155:84532       # Base Sepolia testnet — switch to eip155:8453 for mainnet
FACILITATOR_URL=https://x402.org/facilitator
